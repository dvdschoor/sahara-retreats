---
import Base from "@/layouts/Base.astro";
---

<Base title="Page not found — Sahara Retreats" description="This path has disappeared into the dunes.">
  <section class="not-found">
    <p class="eyebrow">404 · Lost in the dunes</p>
    <h1>This path ends<br /><em>in the sand.</em></h1>
    <a class="text-link" href="/">Return to the retreat <span>↗</span></a>
  </section>
</Base>

<style>
  .not-found { min-height: 100svh; display: flex; flex-direction: column; justify-content: center; padding: 8rem 2rem 3rem; background: var(--sand); }
  h1 { margin-top: 3rem; font-size: clamp(4rem, 11vw, 11rem); line-height: .84; letter-spacing: -.065em; }
  h1 em { color: var(--terracotta); }
  a { width: fit-content; }
</style>
